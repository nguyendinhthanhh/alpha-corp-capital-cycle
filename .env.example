AI_PROVIDER=openai-compatible
AI_BASE_URL=https://example-provider.com/v1
AI_API_KEY=replace_with_your_secret_key
AI_MODEL=replace_with_model_id
AI_DEMO_MODE=false
AI_SERVER_PORT=8787
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_OUTPUT_TOKENS=1000
AI_MAX_INPUT_CHARS=4000
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=24

# Optional legacy compatibility for existing Gemini setup:
# AI_PROVIDER=gemini-native
# GEMINI_API_KEY=replace_with_your_secret_key
# GEMINI_MODEL=gemini-2.5-flash
